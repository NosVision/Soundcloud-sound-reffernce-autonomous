# คัดลอกเป็น .env แล้วใส่ค่า (ไฟล์ .env ถูก gitignore ไม่ขึ้น repo)

# --- SoundCloud ---
# SC_OAUTH_TOKEN=xxxxx        # ใส่ถ้า likes เป็น private
# SC_CLIENT_ID=xxxxx          # ใส่ถ้า auto หา client_id ไม่เจอ
# SC_PROFILE_URL=https://soundcloud.com/your-handle

# --- LINE notify (Phase 3, Messaging API) ---
# LINE_CHANNEL_TOKEN=xxxxx    # Channel access token (long-lived) จาก developers.line.biz
# LINE_TO=Uxxxxxxxx           # userId หรือ groupId ปลายทาง
# (ตั้ง 2 ตัวนี้ครบ = เปิดแจ้งเตือนอัตโนมัติ)
